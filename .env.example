# ============================================================
# Rapide Africa — Environment Variables Template
# ============================================================
# For LOCAL DEV:
#   1. Copy this file to .env
#   2. Fill in actual values
#   3. Never commit .env to git
#
# For VERCEL PRODUCTION:
#   Set these in: Vercel Dashboard → Project → Settings → Environment Variables
#   All VITE_* vars are injected into the client bundle at build time.
# ============================================================

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_AUTH_CALLBACK_URL=https://your-project.supabase.co/auth/v1/callback

# --- Mapbox ---
VITE_MAPBOX_TOKEN=pk.eyJ1Ijoiexample...

# --- Agora (Voice Calls) ---
# App ID is public — safe in client bundle
VITE_AGORA_APP_ID=your-agora-app-id
# App Certificate is SECRET — set only in Supabase Edge Function secrets, never here:
#   supabase secrets set AGORA_APP_ID=...
#   supabase secrets set AGORA_APP_CERTIFICATE=...

# --- DeepL (Chat Translation) ---
# API key is SECRET — set only in Supabase Edge Function secrets, never here:
#   supabase secrets set DEEPL_API_KEY=...

# --- App URL (local dev only) ---
# Not needed on Vercel — the app uses window.location.origin automatically.
# Only set this for local dev (handled automatically in .env.development).
# VITE_APP_URL=http://localhost:5173

# ============================================================
# SUPABASE DASHBOARD CHECKLIST (one-time setup)
# ============================================================
# Authentication → URL Configuration:
#   Site URL:              http://localhost:5173 (dev) or your Vercel domain
#   Redirect URLs:
#     http://localhost:5173/app
#     https://your-app.vercel.app/app           ← add your Vercel URL
#     https://your-custom-domain.com/app        ← add custom domain if any
#
# Google OAuth (if using Google sign-in):
#   Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
# ============================================================
